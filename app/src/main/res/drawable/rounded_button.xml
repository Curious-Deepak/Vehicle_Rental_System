<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background Color -->
    <solid android:color="@color/primary_green" />

    <!-- Rounded Corners -->
    <corners android:radius="16dp" />

    <!-- Inner Padding -->
    <padding
        android:top="12dp"
        android:bottom="12dp"
        android:left="24dp"
        android:right="24dp" />

    <!-- Subtle Shadow (Optional) -->
    <stroke
        android:width="1dp"
        android:color="@color/black" />

</shape>
